{
  "name": "vite-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "_comment": "Development scripts for Vite and linting",
    "dev": "vite",
    "build": "vite build",
    "build:full": "npm run build && cp server.js dist/ && cp package.json dist/ && cp .env dist/",
    "preview": "vite preview",
    "lint": "eslint .",
    "_comment_lintcss": "Runs Stylelint against authored styles and generated utility layers",
    "lint:css": "stylelint \"src/**/*.css\" \"src/assets/**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "lint:css:check": "stylelint \"**/*.css\" --max-warnings 0",
    "analyze": "npx vite-bundle-analyzer dist/stats.html",
    "compress-images": "imagemin public/images/**/*.{webp,jpg,png} --out-dir=public/images --plugin=webp",
    "server": "echo 'Backend is now Express (MERN) - run \"cd backend && npm run dev\"'"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@inertiajs/react": "^2.2.15",
    "@types/react-google-recaptcha": "^2.1.9",
    "date-fns": "^4.1.0",
    "i18next": "^25.6.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.0",
    "react-datepicker": "^8.8.0",
    "react-dom": "^19.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-i18next": "^16.2.4",
    "react-router-dom": "^7.9.5",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "^19.1.0-rc.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "imagemin": "^9.0.1",
    "imagemin-cli": "^8.0.0",
    "imagemin-webp": "^8.0.0",
    "postcss": "^8.5.6",
    "postcss-combine-media-query": "^2.1.0",
    "postcss-merge-rules": "^7.0.6",
    "postcss-preset-env": "^10.4.0",
    "postcss-scss": "^4.0.9",
    "rollup-plugin-visualizer": "^6.0.5",
    "sharp": "^0.34.4",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^6.0.4",
    "terser": "^5.44.0",
    "vite": "^7.1.12"
  }
}
